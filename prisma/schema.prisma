generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Donation {
  id            String   @id @default(cuid())
  pan           String?
  name          String
  address       String
  email         String
  contact       String
  reason        String
  gstno         String   @default("N/A")
  method        String
  amount        Decimal  @db.Decimal(12, 2)
  date          DateTime
  receiptNumber String   @unique
  transactionId String   @unique

  @@index([date])
  @@index([email])
  @@map("donation")
}

model Counter {
  financialYear String @id
  seq           Int

  @@map("counter")
}
