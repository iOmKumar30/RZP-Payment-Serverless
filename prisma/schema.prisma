generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Donation {
  id            String   @id @default(cuid())
  pan           String
  name          String
  address       String
  email         String
  contact       String
  reason        String
  method        String
  amount        Decimal  @db.Decimal(12, 2)
  date          DateTime
  receiptNumber String   @unique
  transactionId String   @unique

  @@index([date])
  @@index([email])
  @@map("donation")
}

model Counter {
  financialYear String @id
  seq           Int

  @@map("counter")
}

model Account {
  id                String   @id
  userId            String
  provider          String
  providerAccountId String
  providerEmail     String?
  accessToken       String?
  refreshToken      String?
  tokenType         String?
  scope             String?
  expiresAt         Int?
  idToken           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime
  User              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Centre {
  id                    String                  @id
  code                  String                  @unique @db.VarChar(12)
  name                  String?
  street_address        String?
  city                  String?
  district              String?
  state                 String?
  pincode               String?                 @db.VarChar(10)
  status                CentreStatus            @default(ACTIVE)
  date_associated       DateTime
  date_left             DateTime?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  Classroom             Classroom[]
  FacilitatorAssignment FacilitatorAssignment[]

  @@index([city, state])
  @@index([status])
}

model Classroom {
  id                         String                       @id
  code                       String?                      @unique @db.VarChar(24)
  centre_id                  String
  section_code               SectionCode?
  timing                     ClassTiming?
  monthly_allowance          Int?
  status                     ClassroomStatus              @default(ACTIVE)
  date_created               DateTime?
  date_closed                DateTime?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime
  city                       String?
  district                   String?
  pincode                    String?                      @db.VarChar(10)
  state                      String?
  street_address             String?
  Centre                     Centre                       @relation(fields: [centre_id], references: [id], onDelete: Cascade)
  MonthlyClassroomAttendance MonthlyClassroomAttendance[]
  StudentClassroomAssignment StudentClassroomAssignment[]
  TutorAssignment            TutorAssignment[]

  @@index([centre_id])
  @@index([status, section_code, timing])
}

model EmailCredential {
  id           String    @id
  userId       String    @unique
  email        String    @unique
  passwordHash String
  passwordSalt String?
  lastLoginAt  DateTime?
  failedCount  Int       @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}

model Employee {
  id          String           @id
  userId      String           @unique
  designation String
  joiningDate DateTime
  status      EmploymentStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime
  User        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FacilitatorAssignment {
  id        String    @id
  userId    String
  centreId  String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  Centre    Centre    @relation(fields: [centreId], references: [id], onDelete: Cascade)
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([centreId, startDate, endDate])
  @@index([userId])
}

model FacilitatorEmployee {
  id                                            String   @id
  facilitatorId                                 String
  employeeUserId                                String
  startDate                                     DateTime
  createdAt                                     DateTime @default(now())
  User_FacilitatorEmployee_employeeUserIdToUser User     @relation("FacilitatorEmployee_employeeUserIdToUser", fields: [employeeUserId], references: [id], onDelete: Cascade)
  User_FacilitatorEmployee_facilitatorIdToUser  User     @relation("FacilitatorEmployee_facilitatorIdToUser", fields: [facilitatorId], references: [id], onDelete: Cascade)

  @@index([employeeUserId])
  @@index([facilitatorId])
}

model MonthlyClassroomAttendance {
  id                    String    @id
  classroomId           String
  year                  Int
  month                 Int
  totalStudentsEnrolled Int
  openDays              Int
  totalPresent          Int
  attendancePercentage  Decimal   @db.Decimal(5, 2)
  register_photo_url    String?
  remarks               String?
  enteredByTutorId      String
  submittedAt           DateTime  @default(now())
  lastUpdatedAt         DateTime
  Classroom             Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  User                  User      @relation(fields: [enteredByTutorId], references: [id])

  @@unique([classroomId, year, month])
  @@index([enteredByTutorId])
  @@index([year, month])
}

model Role {
  id              String            @id
  name            RoleName          @unique
  description     String?
  UserRoleHistory UserRoleHistory[]
}

model RoleRequest {
  id             String    @id
  userId         String
  requestedRoles String
  message        String?
  status         String    @default("PENDING")
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  User           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Student {
  id                         String                       @id
  name                       String
  aadhaarNo                  String?                      @unique(map: "student_aadhaar_unique")
  rollNo                     String                       @unique
  gender                     Gender?
  dob                        DateTime?
  street_address             String?
  city                       String?
  district                   String?
  state                      String?
  pincode                    String?                      @db.VarChar(10)
  fatherName                 String?
  motherName                 String?
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime
  StudentClassroomAssignment StudentClassroomAssignment[]

  @@index([city, state])
}

model StudentClassroomAssignment {
  id          String           @id
  studentId   String
  classroomId String
  join_date   DateTime
  leave_date  DateTime?
  status      AssignmentStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  Classroom   Classroom        @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  Student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([classroomId, join_date, leave_date])
  @@index([studentId, status])
}

model TutorAssignment {
  id           String    @id
  userId       String
  classroomId  String
  startDate    DateTime
  endDate      DateTime?
  isSubstitute Boolean   @default(false)
  createdAt    DateTime  @default(now())
  Classroom    Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  User         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([classroomId, startDate, endDate])
  @@index([isSubstitute])
  @@index([userId])
}

model User {
  id                                                           String                       @id
  name                                                         String?
  email                                                        String                       @unique
  createdAt                                                    DateTime                     @default(now())
  updatedAt                                                    DateTime
  activatedAt                                                  DateTime?
  address                                                      String?
  onboardingStatus                                             OnboardingStatus             @default(PENDING_PROFILE)
  phone                                                        String?
  profileSubmittedAt                                           DateTime?
  roleRequestedAt                                              DateTime?
  status                                                       UserStatus                   @default(ACTIVE)
  sessionVersion                                               Int?                         @default(0)
  Account                                                      Account[]
  EmailCredential                                              EmailCredential?
  Employee                                                     Employee?
  FacilitatorAssignment                                        FacilitatorAssignment[]
  FacilitatorEmployee_FacilitatorEmployee_employeeUserIdToUser FacilitatorEmployee[]        @relation("FacilitatorEmployee_employeeUserIdToUser")
  FacilitatorEmployee_FacilitatorEmployee_facilitatorIdToUser  FacilitatorEmployee[]        @relation("FacilitatorEmployee_facilitatorIdToUser")
  MonthlyClassroomAttendance                                   MonthlyClassroomAttendance[]
  RoleRequest                                                  RoleRequest[]
  TutorAssignment                                              TutorAssignment[]
  UserRoleHistory                                              UserRoleHistory[]

  @@index([email])
  @@index([onboardingStatus])
  @@index([status])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model UserRoleHistory {
  id        String    @id
  userId    String
  roleId    String
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())
  Role      Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roleId])
  @@index([userId, endDate])
  @@index([userId, startDate])
}

enum AssignmentStatus {
  ACTIVE
  LEFT
}

enum CentreStatus {
  ACTIVE
  INACTIVE
}

enum ClassTiming {
  MORNING
  EVENING
}

enum ClassroomStatus {
  ACTIVE
  INACTIVE
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
}

enum Gender {
  M
  F
  O
}

enum OnboardingStatus {
  PENDING_PROFILE
  SUBMITTED_PROFILE
  PENDING_ROLE
  ACTIVE
  REJECTED
}

enum RoleName {
  PENDING
  ADMIN
  TUTOR
  FACILITATOR
  RELF_EMPLOYEE
}

enum SectionCode {
  JR
  SR
}

enum UserStatus {
  ACTIVE
  INACTIVE
}
